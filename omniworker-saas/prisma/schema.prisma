// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── TENANT (Empresa/Organización) ───
model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  planId      String?
  plan        SubscriptionPlan? @relation(fields: [planId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Datos de contacto
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  website       String?
  // Datos fiscales
  taxId         String?
  address       String?
  city          String?
  country       String?
  postalCode    String?
  // Notas internas
  notes         String?

  // Subscription state
  subscriptionEndsAt DateTime?

  users       User[]
  edgeAgents  EdgeAgent[]
  apiKeys     TenantApiKey[]
  tasks       TaskLog[]
}

// ─── API KEYS (para edge agents) ───
model TenantApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  keyHash     String    @unique
  keyPrefix   String
  name        String?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
}

// ─── USER ───
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          String    @default("USER")
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  tokenBalance  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?

  tasks         TaskLog[]
  refreshTokens RefreshToken[]
}

// ─── REFRESH TOKEN ───
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
}

// ─── SUBSCRIPTION PLANS ───
model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  tokenLimit    Int
  maxAgents     Int      @default(1)
  maxUsers      Int      @default(1)
  price         Float
  billingPeriod String   @default("monthly")
  isActive      Boolean  @default(true)
  isPublic      Boolean  @default(true)
  features      String   @default("[]")
  sortOrder     Int      @default(0)

  tenants       Tenant[]
}

// ─── TASK LOG ───
model TaskLog {
  id             String   @id @default(uuid())
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  promptTokens   Int      @default(0)
  completionTks  Int      @default(0)
  modelUsed      String
  taskType       String
  status         String   @default("completed")
  createdAt      DateTime @default(now())
}

// ─── MASTER PROVIDERS — multi-key por proveedor ───
model MasterProvider {
  id           String   @id @default(uuid())
  name         String
  provider     String
  apiKey       String
  defaultModel String   @default("gpt-4o-mini")
  isActive     Boolean  @default(true)
  priority     Int      @default(1)
  dailyLimit   Int?
  usedToday    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── ADMIN AUDIT LOG ───
model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}

// ─── EDGE AGENT ───
model EdgeAgent {
  id            String    @id @default(uuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  agentName     String
  hostname      String?
  platform      String?
  status        String    @default("offline")
  lastSeenAt    DateTime?
  capabilities  String    @default("[]")
  createdAt     DateTime  @default(now())

  @@index([tenantId])
}
