// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT (Empresa/Organización) ───
model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique        // ej: "acme-corp"
  planId      String?
  plan        SubscriptionPlan? @relation(fields: [planId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  users       User[]
  edgeAgents  EdgeAgent[]
  apiKeys     TenantApiKey[]
  tasks       TaskLog[]
}

// ─── API KEYS (para edge agents) ───
model TenantApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  keyHash     String    @unique        // Hashed API key
  keyPrefix   String                   // First 8 chars for identification
  name        String?                  // "Laptop Nelson", "Server ACME"
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
}

// ─── USER ───
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          UserRole  @default(USER)
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])
  tokenBalance  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?

  tasks         TaskLog[]
}

enum UserRole {
  USER
  ADMIN        // Admin del tenant
  SUPERADMIN   // Admin de la plataforma
}

// ─── SUBSCRIPTION PLANS ───
model SubscriptionPlan {
  id              String   @id @default(uuid())
  name            String   @unique // "Free", "Pro", "Enterprise"
  tokenLimit      Int               // Tokens mensuales
  maxAgents       Int      @default(1)
  maxUsers        Int      @default(1)
  price           Float
  isActive        Boolean  @default(true)

  tenants         Tenant[]
}

// ─── TASK LOG (uso/billing) ───
model TaskLog {
  id             String   @id @default(uuid())
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  promptTokens   Int      @default(0)
  completionTks  Int      @default(0)
  modelUsed      String
  taskType       String   // "cloud_reasoning", "edge_tool", "embedding"
  status         String   @default("completed") // "completed", "failed"
  createdAt      DateTime @default(now())
}

// ─── MASTER PROVIDERS (superadmin) ───
model MasterProvider {
  id          String   @id @default(uuid())
  provider    String   @unique // "openai", "anthropic", "deepseek", etc.
  apiKey      String
  isActive    Boolean  @default(true)
  priority    Int      @default(1)
  updatedAt   DateTime @updatedAt
}

// ─── EDGE AGENT (PCs conectadas) ───
model EdgeAgent {
  id            String    @id @default(uuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  agentName     String                   // Nombre identificativo
  hostname      String?                  // Nombre del equipo
  platform      String?                  // "macOS", "Linux", "Windows"
  status        String    @default("offline") // "online", "offline", "busy"
  lastSeenAt    DateTime?
  capabilities  String    @default("[]") // JSON array de tools disponibles
  createdAt     DateTime  @default(now())

  @@index([tenantId])
}
