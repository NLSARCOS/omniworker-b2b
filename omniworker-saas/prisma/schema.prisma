// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── TENANT (Empresa/Organización) ───
model Tenant {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  planId      String?
  plan        SubscriptionPlan? @relation(fields: [planId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Datos de contacto
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  website       String?
  // Datos fiscales
  taxId         String?
  address       String?
  city          String?
  country       String?
  postalCode    String?
  // Notas internas
  notes         String?

  // Subscription state
  subscriptionEndsAt DateTime?

  users       User[]
  edgeAgents  EdgeAgent[]
  apiKeys     TenantApiKey[]
  licenses    License[]
  tasks       TaskLog[]
  invoices    Invoice[]
}

// ─── API KEYS (para edge agents) ───
model TenantApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  // Tenant deletion cascades to all associated Tenant API keys
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licenseId   String?
  // License deletion cascades to all associated Tenant API keys
  license     License?  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  keyHash     String    @unique
  keyPrefix   String
  name        String?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([licenseId])
}

// ─── USER ───
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String?
  role          String    @default("USER")
  tenantId      String?
  // If a Tenant is deleted, users remain but their tenantId is set to NULL
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  tokenBalance  Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?

  tasks         TaskLog[]
  refreshTokens RefreshToken[]

  @@index([tenantId])
}

// ─── REFRESH TOKEN ───
model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@index([family])
}

// ─── SUBSCRIPTION PLANS ───
model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  tokenLimit    Int
  maxAgents     Int      @default(1)
  maxUsers      Int      @default(1)
  maxLicenses   Int      @default(1)
  price         Int      // Price stored in cents
  billingPeriod String   @default("monthly")
  isActive      Boolean  @default(true)
  isPublic      Boolean  @default(true)
  features      String   @default("[]")
  sortOrder     Int      @default(0)

  tenants       Tenant[]
}

// ─── TASK LOG ───
model TaskLog {
  id             String   @id @default(uuid())
  tenantId       String?
  // Tenant deletion cascades to all associated TaskLogs
  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  // User deletion cascades to all associated TaskLogs
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptTokens   Int      @default(0)
  completionTks  Int      @default(0)
  modelUsed      String
  taskType       String
  status         String   @default("completed")
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}

// ─── MASTER PROVIDERS — multi-key por proveedor ───
model MasterProvider {
  id           String   @id @default(uuid())
  name         String
  provider     String
  apiKey       String
  defaultModel String   @default("gpt-4o-mini")
  isActive     Boolean  @default(true)
  priority     Int      @default(1)
  dailyLimit   Int?
  usedToday    Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([provider, isActive])
}

// ─── ADMIN AUDIT LOG ───
model AdminAuditLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  target    String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}

// ─── LICENSE ───────────────────────────────────────────────────────────────
model License {
  id               String    @id @default(uuid())
  tenantId         String
  // Tenant deletion cascades to all associated Licenses
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  status           String    @default("ACTIVE")
  deviceFingerprint String?
  tokenBalance     Int       @default(0)
  activatedAt      DateTime  @default(now())
  lastSeenAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  apiKeys          TenantApiKey[]
  edgeAgents       EdgeAgent[]

  @@index([tenantId])
  @@index([status])
}

// ─── EDGE AGENT ───
model EdgeAgent {
  id            String    @id @default(uuid())
  tenantId      String
  // Tenant deletion cascades to all associated EdgeAgents
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licenseId     String?
  // License deletion cascades to all associated EdgeAgents
  license       License?  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  agentName     String
  hostname      String?
  platform      String?
  status        String    @default("offline")
  lastSeenAt    DateTime?
  capabilities  String    @default("[]")
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([licenseId])
}

// ─── APP UPDATE ───
model AppUpdate {
  id           String   @id @default(uuid())
  version      String   @unique
  urlWindows   String
  urlMac       String
  urlLinux     String
  releaseNotes String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// ─── INVOICE B2B ───
model Invoice {
  id             String   @id @default(uuid())
  tenantId       String
  // Tenant deletion cascades to all associated Invoices
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount         Int      // Amount stored in cents
  currency       String   @default("USD")
  status         String   @default("PAID")
  description    String?
  invoiceNumber  String   @unique
  paymentMethod  String   @default("MANUAL")
  paidAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}