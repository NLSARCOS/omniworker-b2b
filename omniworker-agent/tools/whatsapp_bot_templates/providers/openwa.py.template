"""WhatsApp Bot — OpenWA provider.

Uses the self-hosted OpenWA API gateway for sending and receiving WhatsApp messages.
"""

import os
import logging
import aiohttp

from .base import BaseProvider, IncomingMessage

logger = logging.getLogger("whatsapp_bot.providers.openwa")

OPENWA_SERVER_URL = os.getenv("OPENWA_SERVER_URL", "${openwa_server_url}")
OPENWA_API_KEY = os.getenv("OPENWA_API_KEY", "${openwa_api_key}")

# We will dynamically capture sessionId from webhooks or list sessions API
_LAST_SESSION_ID = "default"

class OpenwaProvider(BaseProvider):
    """OpenWA WhatsApp provider."""

    def parse_webhook(self, body: dict) -> list[IncomingMessage]:
        global _LAST_SESSION_ID
        messages = []
        
        # OpenWA sends event payloads
        event = body.get("event")
        if event != "message.received":
            return messages
            
        session_id = body.get("sessionId")
        if session_id:
            _LAST_SESSION_ID = session_id
            
        data = body.get("data", {})
        sender = data.get("from", "")
        text = data.get("body", "")
        
        if sender and text:
            messages.append(IncomingMessage(sender=sender, text=text))
        return messages

    async def _get_session_id(self) -> str:
        global _LAST_SESSION_ID
        # Let's try to query the active sessions list to see if there is an active session
        url = f"{OPENWA_SERVER_URL.rstrip('/')}/api/sessions"
        headers = {
            "X-API-Key": OPENWA_API_KEY,
            "Content-Type": "application/json",
        }
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get(url, headers=headers) as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        # OpenWA returns a list or an object. Let's handle list
                        if isinstance(data, list) and len(data) > 0:
                            # Use first active session
                            for s in data:
                                if s.get("status") == "CONNECTED" or s.get("name"):
                                    return s.get("name") or s.get("id")
                            return data[0].get("name") or data[0].get("id")
                        elif isinstance(data, dict):
                            # In case it's a dict containing a list of sessions
                            sessions_list = data.get("sessions") or data.get("data", [])
                            if isinstance(sessions_list, list) and len(sessions_list) > 0:
                                return sessions_list[0].get("name") or sessions_list[0].get("id")
        except Exception:
            logger.debug("Failed to list OpenWA sessions, using last seen or default")
            
        return _LAST_SESSION_ID

    async def send_message(self, recipient: str, text: str) -> bool:
        session_id = await self._get_session_id()
        # openwa endpoint: POST /api/sessions/{sessionId}/messages/send-text
        url = f"{OPENWA_SERVER_URL.rstrip('/')}/api/sessions/{session_id}/messages/send-text"
        headers = {
            "X-API-Key": OPENWA_API_KEY,
            "Content-Type": "application/json",
        }
        payload = {
            "chatId": recipient,
            "text": text
        }
        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(url, json=payload, headers=headers) as resp:
                    if resp.status == 200 or resp.status == 201:
                        return True
                    else:
                        logger.error("OpenWA send_message failed: %s - %s", resp.status, await resp.text())
                        return False
        except Exception:
            logger.exception("Error sending OpenWA message to %s", recipient)
            return False
